# Copy this file to backend/config/stripe.env for local Stripe testing.
# Keep backend/config/stripe.env out of git because it contains secrets.

BILLING_MODE=stripe
PUBLIC_APP_URL=http://127.0.0.1:5173

STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_cli_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_recurring_price_id
